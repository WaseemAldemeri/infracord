{
	"name": "infracord",
	"version": "0.1.0",
	"description": "A declarative, type-safe framework for Discord bots built on discord.js",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"discord",
		"discord.js",
		"bot",
		"framework"
	],
	"license": "MIT",
	"dependencies": {
		"discord.js": "^14.25.1"
	},
	"devDependencies": {
		"tsdown": "^0.21.7",
		"vitest": "^4.1.4"
	}
}
